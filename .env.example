ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>     # server-side only, never ship to a client
RETENTION_DAYS=14                            # mirrors app_settings; informational
SUM_TOLERANCE=0.01                           # grand-total reconciliation tolerance
VISION_CONF_THRESHOLD=medium                 # min model confidence to write a value
PRICE_SANITY_MAX=7500                        # line price at/above this flags as a likely misread

# Optional: when true, the app runs without Supabase/Anthropic and uses a local
# on-disk store + deterministic-only extraction. Useful for local UI development
# and for running the bundled fixtures offline. Set to false in production.
OFFLINE_MODE=false

# Local data directory used only when OFFLINE_MODE=true (mimics Storage buckets).
LOCAL_DATA_DIR=.localdata
